# HALO environment variables
#
# Copy this file to .env and fill in real values. Never commit .env.
#
#     cp .env.example .env
#     # then edit .env with real keys
#
# The .env file is gitignored.

# Required for the Layer 2 Solar-pro cloud prototype demo
# Get a key at https://console.upstage.ai
UPSTAGE_API_KEY=

# Optional. Weights & Biases project for LoRA fine-tuning runs (M2+)
WANDB_API_KEY=
WANDB_PROJECT=halo

# Optional. HuggingFace token if you pull K-intelligence/Midm-2.0-Base-Instruct
HF_TOKEN=
